# Railway PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/cargo_stock"

# NextAuth.js configuration
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The URL where the app is hosted (Railway provides this automatically)
AUTH_URL="http://localhost:3000"

# AIS Stream API key (live vessel data via WebSocket)
# Get one for free at https://aisstream.io
# Optional - if not set, the external-ships integration is disabled gracefully
AISSTREAM_API_KEY=""

# Evolution API (WhatsApp gateway) — deploy as a sibling service on Railway.
# URL: internal Railway URL when both services live in the same project, e.g.
# http://evolution-api.railway.internal:8080 (no public exposure needed).
# Key: matches AUTHENTICATION_API_KEY set on the Evolution service.
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE=""

# Mercado Livre (API oficial) — puxa as palavras-chave oficiais do produto pelo
# link (Solicitações/Compras) e as inclui no aviso de "compra concluída" no
# WhatsApp. Crie/abra o app em https://developers.mercadolivre.com.br e:
#   1) Cadastre o Redirect URI EXATAMENTE como:
#        <AUTH_URL>/api/integrations/mercado-livre/callback
#      ex.: https://cargostock-production.up.railway.app/api/integrations/mercado-livre/callback
#   2) Deixe a opção "PKCE" DESATIVADA (usamos client confidencial com secret).
# Sem essas variáveis a integração fica desligada (a raspagem do link continua).
MERCADO_LIVRE_CLIENT_ID=""
MERCADO_LIVRE_CLIENT_SECRET=""
# Opcional — força o Redirect URI. Se vazio, deriva de AUTH_URL (acima).
MERCADO_LIVRE_REDIRECT_URI=""
