# Railway PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/cargo_stock"

# NextAuth.js configuration
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The URL where the app is hosted (Railway provides this automatically)
AUTH_URL="http://localhost:3000"

# AIS Stream API key (live vessel data via WebSocket)
# Get one for free at https://aisstream.io
# Optional - if not set, the external-ships integration is disabled gracefully
AISSTREAM_API_KEY=""

# Evolution API (WhatsApp gateway) — deploy as a sibling service on Railway.
# URL: internal Railway URL when both services live in the same project, e.g.
# http://evolution-api.railway.internal:8080 (no public exposure needed).
# Key: matches AUTHENTICATION_API_KEY set on the Evolution service.
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE=""

# Secret for the /api/cron/* fallback routes (manual/external trigger of the
# in-process scheduler). Any random string; pass as ?secret= or x-cron-secret.
CRON_SECRET=""

# Financeiro (Contas a Pagar + Conciliação) — key used to encrypt credentials
# at rest (Microsoft Graph tokens, bank certificates). 32 bytes in base64:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FINANCE_ENCRYPTION_KEY=""

# Captura de boletos por e-mail (Microsoft Graph, app-only / client credentials).
# App registration (multi-tenant) no Azure AD; a caixa (GRAPH_MAILBOX) é cadastrada
# na tela Financeiro › E-mail. Enquanto vazio, a captura fica inerte (sem erro).
# GRAPH_TENANT_ID: tenant que DONO da caixa (o do cliente, não o da Azaztech).
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
GRAPH_TENANT_ID=""
