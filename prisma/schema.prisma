generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  GESTOR
  EXECUTIVO
  MANUTENCAO
  FINANCEIRO
  RH
  TECNOLOGIA
  ESTAGIO // mesmas permissões de TECNOLOGIA (ver rbac); categoria "Estágio"
  COMERCIAL // mesmas permissões de EXECUTIVO (ver rbac); categoria "Comercial"
}

enum StockCategory {
  COMPRAS
  CARNES
  CARNE
  FEIRA
  SUPRIMENTOS
  OUTROS
}

enum MovementType {
  ENTRADA
  BAIXA
  AJUSTE
}

enum EpiMovementType {
  ENTREGA
  DEVOLUCAO
}

enum ToolStatus {
  DISPONIVEL
  EQUIPE_1
  EQUIPE_2
  MANUTENCAO
}

enum ToolMovementType {
  EQUIPE_1
  EQUIPE_2
  DEVOLUCAO
  MANUTENCAO
}

enum AssetType {
  FERRAMENTA
  MAQUINARIO
  ELETRICA
}

enum ShipStatus {
  AGENDADO
  EM_OPERACAO
  CONCLUIDO
  CANCELADO
}

// ── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  password_hash String
  full_name     String
  role          Role       @default(RH)
  created_at    DateTime   @default(now()) @db.Timestamptz()
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamptz()
  login_logs    LoginLog[]

  @@map("users")
}

// ── Stock ────────────────────────────────────────────────────────────────────

model StockItem {
  id               Int             @id @default(autoincrement())
  name             String
  category         StockCategory   @default(OUTROS)
  // Unidade de medida do item (UN, KG, FARDO, L, CX, PCT, DZ, SACO). Carne = KG.
  unit             String          @default("UN")
  location         String?
  // Float (não Int) pra aceitar quantidades quebradas: 1,5 kg, 1,67, etc.
  quantity         Float           @default(0)
  default_quantity Float           @default(0)
  team             String?
  // Onde o item está, nas abas de inventário (Estoque/Ferramenta/Elétrica/Fluídos):
  // null/"DISPONIVEL" = no almoxarifado; "EQUIPE_1"/"EQUIPE_2" = levado pela equipe.
  // (Rancho usa o próprio `team` pra separar as equipes; aqui `team` é o setor.)
  assigned_team    String?
  expiry_date      DateTime?       @db.Date
  min_quantity     Int             @default(0)
  // Foto opcional do produto (data URL base64 comprimida no cliente). Inline no
  // banco — infra só Railway/Postgres, sem storage externo (igual tool_requests).
  image_url        String?
  // Observação livre do item (ex.: specs técnicas de itens elétricos). Antes
  // ficava em `tools.notes` (Ferramenta/Elétrica eram empréstimo).
  notes            String?
  // Valor unitário do item (R$). Dado sensível: só STOCK_VALUE_ROLES (rbac) vê —
  // a coluna é filtrada no /api/db, não só escondida na tela. Rancho não usa.
  unit_value       Float           @default(0)
  updated_at       DateTime        @default(now()) @db.Timestamptz()
  updated_by       String
  stock_movements  StockMovement[]
  embark_kit_items EmbarkKitItem[]
  embark_list_overrides EmbarkListOverride[]

  @@index([category])
  @@map("stock_items")
}

// Kit de embarque por equipe: quanto de cada material (stock_item do galpão,
// team=GALPAO) cada equipe leva ao navio. Ao "Embarcar", essas quantidades são
// baixadas do Estoque de materiais. Montado a partir do Check List; a Equipe 2
// começa como cópia da Equipe 1.
model EmbarkKitItem {
  id            Int       @id @default(autoincrement())
  team          String // EQUIPE_1, EQUIPE_2, EQUIPE_3
  stock_item_id Int
  quantity      Float     @default(0)
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz()
  stock_items   StockItem @relation(fields: [stock_item_id], references: [id], onDelete: Cascade)

  @@unique([team, stock_item_id])
  @@index([team])
  @@map("embark_kit_items")
}

// Ajuste da lista de embarque POR NAVIO (aba Embarque/Retorno): muda quanto a
// equipe leva de um item do kit/rancho SÓ naquele navio (em caso de falta, ou
// pra levar mais), ou adiciona um item do Estoque/Rancho que não está na lista
// padrão. O kit oficial (embark_kit_items) e o padrão do Rancho ficam intactos.
model EmbarkListOverride {
  id            Int       @id @default(autoincrement())
  ship_id       String    @db.Uuid
  ships         Ship      @relation(fields: [ship_id], references: [id], onDelete: Cascade)
  // Equipe do navio quando o ajuste foi feito — trocando a equipe do navio, os
  // ajustes da equipe antiga ficam dormentes (a tela filtra por team).
  team          String
  kind          String // MATERIAL (kit do Estoque/GALPAO) | RANCHO (comida da equipe)
  stock_item_id Int
  stock_items   StockItem @relation(fields: [stock_item_id], references: [id], onDelete: Cascade)
  quantity      Float     @default(0)
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz()

  @@unique([ship_id, stock_item_id])
  @@index([ship_id])
  @@map("embark_list_overrides")
}

model StockMovement {
  id            Int          @id @default(autoincrement())
  stock_item_id Int
  movement_type MovementType
  quantity      Float
  movement_date DateTime     @default(now()) @db.Date
  notes         String?
  created_by    String
  created_at    DateTime     @default(now()) @db.Timestamptz()
  stock_items   StockItem    @relation(fields: [stock_item_id], references: [id], onDelete: Cascade)

  @@index([stock_item_id])
  @@map("stock_movements")
}

// ── Employees ────────────────────────────────────────────────────────────────

model Employee {
  id                   Int       @id @default(autoincrement())
  name                 String
  team                 String?
  birth_date           DateTime? @db.Date
  phone                String?
  email                String?
  family_phone         String?
  notes                String?
  bank_name            String?
  bank_agency          String?
  bank_account         String?
  bank_account_type    String?
  has_vaccination_card Boolean?  @default(false)
  has_cnh              Boolean?  @default(false)

  // ── Identificação (planilha oficial) ───────────────────────────────────────
  cpf                  String?   @unique
  rg                   String?
  isps_code            String?
  e_social             String?
  subestipulante       Int?
  modulo               Int?

  // ── Vínculo / Status ───────────────────────────────────────────────────────
  status               String?   @default("ATIVO")           // ATIVO, INATIVO, PENDENCIA
  sector               String?                                // OPERACIONAL, ADMINISTRATIVO
  role                 String?                                // WAP, AJUDANTE, ESFREGAO, ANALISTA_RH, OPERACIONAL...
  salary               Decimal?  @db.Decimal(10, 2)           // futuro: cálculo de folha
  admission_date       DateTime? @db.Date
  // Data limite p/ gozo de férias (coluna "Limite p/ gozo" da Programação de
  // Férias da contabilidade): prazo legal pra tirar as férias do período
  // aquisitivo mais antigo em aberto. Passou = férias vencidas.
  vacation_limit_date  DateTime? @db.Date
  dismissal_date       DateTime? @db.Date                     // data de demissão (preenchida quando status = INATIVO)
  contract_type        String?                                // REGISTRADO, INTERMITENTE

  // ── Treinamentos (datas em texto livre vindas da planilha) ─────────────────
  nrs_training         String?                                // NR 1,6,7,17,29,35
  meio_ambiente_training String?
  lifeguard_training   Boolean?  @default(false)              // SALVA VIDAS
  rubber_boot          Boolean?  @default(false)              // BOTA BORRACHA

  // ── Tamanhos de EPI/uniforme ───────────────────────────────────────────────
  boot_size            String?
  shirt_size           String?
  bermuda_size         String?

  // ── ASO (atestado médico) ──────────────────────────────────────────────────
  last_aso_date        String?                                // texto livre da planilha
  aso_status           String?                                // OK, INATIVO, VENCIDO

  // ── Operacional ────────────────────────────────────────────────────────────
  realiza_limpeza      Boolean?  @default(false)
  does_costado         Boolean?  @default(false)
  escala_unavailable   Boolean?  @default(false)             // marcado = Inativo na escalação: some das telas de Embarque/Costado e mostra "Inativo" na coluna Escalação

  updated_at           DateTime  @default(now()) @db.Timestamptz()
  updated_by           String

  job_allocations      JobAllocation[]
  function_rates       EmployeeFunctionRate[]
  advances             EmployeeAdvance[]

  @@map("employees")
}

// ── Relatório de Vales (adiantamentos) ───────────────────────────────────────
// Espelha o "Relatório de Vales <ano>.xlsx" (SERVIDOR - Documentos › 2 -DIRETORIA
// › 00 - FUNCIONÁRIOS - CONTROLE DE PAGAMENTOS): o funcionário pega dinheiro
// adiantado na empresa e isso é descontado depois, no pagamento de um navio.
//
// Na planilha são duas metades da mesma linha: as colunas ADIANTAMENTO (quanto
// pegou, uma coluna por evento: "Folha 04/07/2026", "Pegou com a Rose") e as
// colunas DESCONTAR-NAVIO (quanto já voltou, uma coluna por navio). O
// "TOTAL A DESCONTAR" é o saldo: adiantado − descontado.
//
// Aqui isso vira duas tabelas: o vale (EmployeeAdvance) e cada desconto dele num
// navio (AdvanceDiscount). O saldo é sempre calculado, nunca gravado — assim não
// tem como o saldo divergir dos descontos.
model EmployeeAdvance {
  id           Int      @id @default(autoincrement())
  employee_id  Int
  employees    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  advance_date DateTime @db.Date // quando o funcionário pegou
  // Sempre positivo. O saldo em aberto = amount − Σ discounts.amount.
  amount       Decimal  @db.Decimal(10, 2)
  // De onde saiu o dinheiro, como na planilha: "Folha 04/07/2026",
  // "Pegou com a Rose 07/07/2026", "Pix Francisco"...
  origin       String
  notes        String?
  created_by   String
  created_at   DateTime @default(now()) @db.Timestamptz()

  discounts AdvanceDiscount[]

  @@index([employee_id])
  @@map("employee_advances")
}

// Um desconto de vale no pagamento de um navio. Aponta pro job + employee (e não
// pra alocação) porque no Costado a mesma pessoa tem várias alocações no mesmo
// navio — uma por turno — e o desconto é um só, do navio inteiro.
//
// Não mexe no custo do navio: o dinheiro já saiu quando o vale foi criado. Só
// reduz o que a pessoa recebe agora (coluna ADIANTAMENTO da Folha de Pagamento).
model AdvanceDiscount {
  id          Int             @id @default(autoincrement())
  advance_id  Int
  advances    EmployeeAdvance @relation(fields: [advance_id], references: [id], onDelete: Cascade)
  job_id      String
  jobs        Job             @relation(fields: [job_id], references: [id], onDelete: Cascade)
  employee_id Int
  // Sempre positivo; nunca pode passar do saldo do vale (validado na tela).
  amount      Decimal         @db.Decimal(10, 2)
  created_by  String
  created_at  DateTime        @default(now()) @db.Timestamptz()

  @@index([advance_id])
  @@index([job_id, employee_id])
  @@map("advance_discounts")
}

// ── Config Pluxee (Navios PLUXEE / PLANSIP4C) ────────────────────────────────
// Linha única (id=1) com os dados FIXOS da empresa que se repetem em todo
// arquivo Pluxee: código do cliente, carteira, endereço de entrega e
// responsável. O que muda por navio (valor do cartão = líquido − folha) sai
// das job_allocations.pluxee_value, não daqui.
model PluxeeConfig {
  id                Int      @id @default(1)
  client_code       String?                                // "Código Cliente Pluxee" (ex.: 3705075)
  order_type        String?  @default("001 - Pedido Normal") // "Tipo do pedido"
  product           String?  @default("603903 - Carteira Gift") // "Produto" (carteira)
  delivery_place    String?  @default("Matriz")            // "Local de entrega"
  cep               String?
  address           String?                                // "Endereço" (logradouro)
  number            String?                                // "Número"
  complement        String?                                // "Complemento"
  reference         String?                                // "Referência"
  neighborhood      String?                                // "Bairro"
  city              String?
  uf                String?
  responsible_name  String?                                // "Responsável pelo recebimento"
  responsible_ddd   String?
  responsible_phone String?
  inactive_value    Decimal? @default(1) @db.Decimal(10, 2) // valor dos Inativos (R$ 1,00)
  updated_at        DateTime @default(now()) @db.Timestamptz()
  updated_by        String?

  @@map("pluxee_config")
}

// ── EPIs ─────────────────────────────────────────────────────────────────────

model Epi {
  id            Int           @id @default(autoincrement())
  name          String
  ca_code       String?
  size          String?
  stock_qty     Int           @default(0)
  min_quantity  Int           @default(0) // mínimo desejado em estoque (0 = sem mínimo); abaixo disso entra na lista de compras
  // Valor unitário (R$) — visível só p/ STOCK_VALUE_ROLES; filtrado no /api/db.
  unit_value    Float         @default(0)
  updated_at    DateTime      @default(now()) @db.Timestamptz()
  updated_by    String
  epi_movements EpiMovement[]

  @@map("epis")
}

model EpiMovement {
  id            Int             @id @default(autoincrement())
  epi_id        Int
  employee_name String
  movement_type EpiMovementType
  quantity      Int             @default(1)
  movement_date DateTime        @default(now()) @db.Date
  notes         String?
  created_by    String
  created_at    DateTime        @default(now()) @db.Timestamptz()
  epis          Epi             @relation(fields: [epi_id], references: [id], onDelete: Cascade)

  @@index([epi_id])
  @@map("epi_movements")
}

// ── Uniforms ─────────────────────────────────────────────────────────────────

model Uniform {
  id                Int               @id @default(autoincrement())
  name              String
  size              String?
  stock_qty         Int               @default(0)
  min_quantity      Int               @default(0) // mínimo desejado em estoque (0 = sem mínimo); abaixo disso entra na lista de compras
  // Valor unitário (R$) — visível só p/ STOCK_VALUE_ROLES; filtrado no /api/db.
  unit_value        Float             @default(0)
  updated_at        DateTime          @default(now()) @db.Timestamptz()
  updated_by        String
  uniform_movements UniformMovement[]

  @@map("uniforms")
}

model UniformMovement {
  id            Int             @id @default(autoincrement())
  uniform_id    Int
  employee_name String
  movement_type EpiMovementType
  quantity      Int             @default(1)
  movement_date DateTime        @default(now()) @db.Date
  notes         String?
  created_by    String
  created_at    DateTime        @default(now()) @db.Timestamptz()
  uniforms      Uniform         @relation(fields: [uniform_id], references: [id], onDelete: Cascade)

  @@index([uniform_id])
  @@map("uniform_movements")
}

// ── Tools / Machinery ────────────────────────────────────────────────────────

model Tool {
  id             Int            @id @default(autoincrement())
  name           String
  status         ToolStatus     @default(DISPONIVEL)
  location       String?
  notes          String?
  asset_type     AssetType      @default(FERRAMENTA)
  updated_at     DateTime       @default(now()) @db.Timestamptz()
  updated_by     String
  tool_movements ToolMovement[]

  @@index([asset_type])
  @@index([status])
  @@map("tools")
}

model ToolMovement {
  id            Int              @id @default(autoincrement())
  tool_id       Int
  employee_name String
  movement_type ToolMovementType
  movement_date DateTime         @default(now()) @db.Date
  notes         String?
  created_by    String
  created_at    DateTime         @default(now()) @db.Timestamptz()
  tools         Tool             @relation(fields: [tool_id], references: [id], onDelete: Cascade)

  @@index([tool_id])
  @@map("tool_movements")
}

// Configurações simples chave/valor do sistema. Primeiro uso: o mínimo de
// máquinas que devem estar disponíveis no Maquinário (key="maquinario_min_disponivel").
// value é texto livre — quem lê interpreta (número, JSON, etc.).
model AppSetting {
  key        String   @id
  value      String
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()
  updated_by String?

  @@map("app_settings")
}

// Conversas (DM ou grupo) travadas pra NÃO permitir envio manual de mensagem —
// o "cadeado" por conversa na aba Conversas. Presença = bloqueada. Não afeta
// boletins agendados (o scheduler envia pela função direta, não pela rota /send).
model LockedConversation {
  remote_jid String   @id
  locked_by  String?
  locked_at  DateTime @default(now()) @db.Timestamptz()

  @@map("locked_conversations")
}

// ── Mission Standard Items ───────────────────────────────────────────────────

model MissionStandardItem {
  id            Int    @id @default(autoincrement())
  name          String
  embark_name   String
  category      String
  required_qty  Int    @default(0)
  display_order Int    @default(0)

  @@index([embark_name])
  @@map("mission_standard_items")
}

// ── Ships ────────────────────────────────────────────────────────────────────

model Ship {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  arrival_date   DateTime?     @db.Date
  departure_date DateTime?     @db.Date
  port           String?
  status         ShipStatus    @default(AGENDADO)
  assigned_team  String?
  notes          String?
  cargo_type     String?       // produto/carga: CARVÃO, CIMENTO, UREIA, etc.
  holds_count    Int?          // quantidade de porões
  client_name    String?       // cliente que contratou o serviço (texto livre)
  services       String[]      @default([]) // serviços executados: LAVAGEM_PORAO, PINTURA, RASPAGEM, COSTADO
  // Situação do embarque, usada pra adaptar a copy do grupo do WhatsApp.
  //   VISTORIA      = "Navio passando por vistoria" (sem horário)
  //   IMEDIATO      = "Embarque imediato" (sem horário)
  //   AGENDADO      = "Embarque agendado" — usa boarding_scheduled_at pro horário
  //   PERSONALIZADO = texto livre do usuário — usa boarding_custom_text
  // Null = não informado (copy genérica, comportamento legado).
  boarding_situation    String?
  boarding_scheduled_at DateTime? @db.Timestamptz()
  // Texto livre da situação quando boarding_situation = "PERSONALIZADO".
  boarding_custom_text  String?
  whatsapp_group_jid String?   // JID do grupo do WhatsApp deste navio (ex.: "12036...@g.us") — alvo da mensagem automática de escalação
  created_by     String
  created_at     DateTime      @default(now()) @db.Timestamptz()
  externalShipId String?
  externalShip   ExternalShip? @relation(fields: [externalShipId], references: [id])
  jobs           Job[]
  material_returns MaterialReturn[]
  embark_list_overrides EmbarkListOverride[]

  @@map("ships")
}

// ── Retorno de materiais (Embarque/Retorno) ──────────────────────────────────
// Quando o navio volta, a manutenção confere o material que embarcou: quanto
// voltou bom e quanto voltou quebrado, item por item. O que volta bom credita o
// Estoque de novo (movimento de ENTRADA); o quebrado fica de fora e é anotado.
// Um registro por conferência (dá pra ter mais de uma por navio); a lista de
// quebrados pode ser mandada pro grupo do WhatsApp das solicitações.
model MaterialReturn {
  id         Int      @id @default(autoincrement())
  ship_id    String   @db.Uuid
  ships      Ship     @relation(fields: [ship_id], references: [id], onDelete: Cascade)
  team       String // EQUIPE_1 / EQUIPE_2 / EQUIPE_3
  notes      String?
  created_by String
  created_at DateTime @default(now()) @db.Timestamptz()

  material_return_items MaterialReturnItem[]

  @@index([ship_id])
  @@map("material_returns")
}

model MaterialReturnItem {
  id              Int            @id @default(autoincrement())
  return_id       Int
  material_return MaterialReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)
  // Material do Estoque de onde saiu/volta (null se o item não existe mais).
  stock_item_id   Int?
  item_name       String // snapshot do nome, pra história não sumir se o item for apagado
  went_qty        Int    @default(0) // referência: quanto foi (kit da equipe)
  returned_qty    Int    @default(0) // voltou em bom estado (credita o Estoque)
  broken_qty      Int    @default(0) // voltou quebrado (não credita; vai pro aviso)
  note            String? // o que quebrou / observação da manutenção

  @@index([return_id])
  @@map("material_return_items")
}

// ── Modelos de "Situação do Embarque" salvos pelo usuário ───────────────────
// Textos livres que o RH escreve uma vez na situação PERSONALIZADO e reaproveita
// em outros navios depois. Compartilhados por toda a equipe (não são por usuário).
model BoardingSituationTemplate {
  id         Int      @id @default(autoincrement())
  text       String
  created_by String
  created_at DateTime @default(now()) @db.Timestamptz()

  @@map("boarding_situation_templates")
}

// ── Sistema Financeiro: Funções, Trabalhos, Alocações ───────────────────────

model JobFunction {
  id              Int                    @id @default(autoincrement())
  name            String                 @unique
  description     String?
  default_rate    Decimal                @default(0) @db.Decimal(10, 2)
  // POR_NAVIO, PORAO, POR_DIA, POR_HORA, POR_OPERACAO = porão de Embarque;
  // TURNO = turno de 6h de Costado; MENSALISTA = admin.
  unit            String                 @default("POR_NAVIO")
  active          Boolean                @default(true)
  rates           JobFunctionRate[]
  allocations     JobAllocation[]
  employee_rates  EmployeeFunctionRate[]
  created_at      DateTime               @default(now()) @db.Timestamptz()
  updated_at      DateTime               @updatedAt @db.Timestamptz()

  @@map("job_functions")
}

// (CostadoFunctionRate foi removido — Costado virou uma função única na
// JobFunction com unit=TURNO e default_rate=valor por turno. Não há mais
// distinção por função nem adicional noturno: valor fixo, igual pra todos.)

// Override do default_rate por funcionário. Quando uma alocação é criada,
// usamos este valor (se houver) em vez do default_rate da função — assim
// funcionários antigos que ganham um pouco a mais ficam com o valor certo.
model EmployeeFunctionRate {
  id            Int         @id @default(autoincrement())
  employee_id   Int
  function_id   Int
  rate          Decimal     @db.Decimal(10, 2)
  notes         String?
  created_at    DateTime    @default(now()) @db.Timestamptz()
  updated_at    DateTime    @updatedAt @db.Timestamptz()

  employees     Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  job_functions JobFunction @relation(fields: [function_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, function_id])
  @@index([function_id])
  @@map("employee_function_rates")
}

model JobFunctionRate {
  id            Int         @id @default(autoincrement())
  function_id   Int
  job_functions JobFunction @relation(fields: [function_id], references: [id], onDelete: Cascade)
  rate          Decimal     @db.Decimal(10, 2)
  valid_from    DateTime    @db.Date
  valid_until   DateTime?   @db.Date // null = vigente
  notes         String?
  created_at    DateTime    @default(now()) @db.Timestamptz()

  @@index([function_id, valid_from])
  @@map("job_function_rates")
}

model Job {
  id             String          @id @default(cuid())
  name           String
  ship_id        String?         @db.Uuid
  ships          Ship?           @relation(fields: [ship_id], references: [id])
  start_date     DateTime        @db.Date
  end_date       DateTime?       @db.Date
  status         String          @default("ABERTO") // ABERTO, EM_ANDAMENTO, VERIFICADO, FECHADO, CANCELADO
  contract_value Decimal?        @db.Decimal(12, 2) // valor que o cliente paga
  notes          String?

  // ── Metadata para fechamento ─────────────────────────────────────────────
  client      String? // ex: DEEP
  supervisor  String? // ex: ADELMO
  cargo_type  String? // ex: CARVÃO
  holds_count Int? // nº de porões (5 PORÕES)
  port        String? // SANTOS, etc.

  // ── Workflow / Audit Trail ───────────────────────────────────────────────
  verified_at   DateTime? @db.Timestamptz()
  verified_by   String? // quem conferiu os valores totais
  closed_at     DateTime? @db.Timestamptz() // último OK
  closed_by     String? // quem fechou junto à contabilidade
  payroll_value Decimal?  @db.Decimal(12, 2) // valor da folha (preenchido pelo gerente — vem da contabilidade)

  allocations JobAllocation[]
  adjustments JobAdjustment[]
  advance_discounts AdvanceDiscount[]
  created_at  DateTime        @default(now()) @db.Timestamptz()
  updated_at  DateTime        @updatedAt @db.Timestamptz()
  created_by  String

  @@index([status])
  @@index([start_date])
  @@map("jobs")
}

model JobAllocation {
  id            Int         @id @default(autoincrement())
  job_id        String
  jobs          Job         @relation(fields: [job_id], references: [id], onDelete: Cascade)
  function_id   Int
  job_functions JobFunction @relation(fields: [function_id], references: [id])
  employee_id   Int? // opcional — registra exatamente quem
  employees     Employee?   @relation(fields: [employee_id], references: [id], onDelete: SetNull)
  quantity      Int         @default(1) // dias trabalhados
  rate          Decimal     @db.Decimal(10, 2) // valor diário aplicado
  pluxee_value  Decimal?    @default(0) @db.Decimal(10, 2) // parte paga via Pluxee
  // Valor extra recebido por rateio (quando o time foi menor que o ideal e o
  // valor de quem faltou foi dividido entre os que foram). null/0 = sem rateio.
  extra_value   Decimal?    @default(0) @db.Decimal(10, 2)
  extra_reason  String? // ex: "Rateio: 1 WAP faltou, valor dividido entre 3"
  notes         String?
  kind          String      @default("EMBARQUE") // EMBARQUE ou COSTADO — qual escalação
  // Override de função TRAVADO pelo executivo só neste navio: quando true, a
  // normalização (função/valor vêm do cadastro) NÃO reescreve esta alocação —
  // function_id e rate ficam como o executivo definiu aqui.
  function_locked Boolean   @default(false)

  // ── Costado: turno (somente quando kind=COSTADO) ────────────────────────
  shift_date    DateTime? @db.Date           // dia da escala
  shift_period  String?                       // "07-13", "13-19", "19-01", "01-07"

  // ── Status & Histórico ─────────────────────────────────────────────────
  status         String    @default("ATIVO") // ATIVO, REMOVIDO, SUBSTITUIDO
  replaces_id    Int? // se for substituto, aponta para a alocação substituída
  replaces       JobAllocation?  @relation("AllocReplacement", fields: [replaces_id], references: [id])
  replaced_by    JobAllocation[] @relation("AllocReplacement")
  added_by       String    @default("")
  added_at       DateTime  @default(now()) @db.Timestamptz()
  removed_by     String?
  removed_at     DateTime? @db.Timestamptz()
  removal_reason String?

  @@index([job_id])
  @@index([status])
  @@index([kind])
  @@index([shift_date, shift_period])
  @@map("job_allocations")
}

// ── Costado: marca de período "não requisitado" ─────────────────────────────
// Quando o navio não opera num turno (ex.: 19-01 do dia 12/05 está parado),
// o gestor marca pra deixar registrado que aquele período não precisava de
// equipe. Difere do "ninguém escalado" (que seria uma falta).
model CostadoPeriodStatus {
  id            Int      @id @default(autoincrement())
  job_id        String
  shift_date    DateTime @db.Date
  shift_period  String // "07-13" | "13-19" | "19-01" | "01-07"
  status        String   @default("NAO_REQUISITADO") // futuro: outros estados
  created_by    String
  created_at    DateTime @default(now()) @db.Timestamptz()

  @@unique([job_id, shift_date, shift_period])
  @@index([job_id])
  @@map("costado_period_status")
}

model JobAdjustment {
  id          Int      @id @default(autoincrement())
  job_id      String
  jobs        Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  type        String // ADICIONAL, REDUCAO
  // Categoria estruturada da despesa — usada pela planilha de fechamento
  // pra agrupar os gastos. Valores: COMPRAS, QUIMICA, MATERIAL_DANIFICADO,
  // AJUDA_DE_CUSTO, ALIMENTACAO, RESTAURANTE, REPASSE (lançado pelo modal
  // "Pagar" do Pagamento de Navios), OUTROS. Null = legado/sem categoria
  // (renderiza como "Outros").
  category    String?
  description String
  amount      Decimal  @db.Decimal(10, 2) // sempre positivo; type define se soma ou subtrai
  created_at  DateTime @default(now()) @db.Timestamptz()

  @@index([job_id])
  @@map("job_adjustments")
}

// ── External Ships (MarineTraffic cache) ─────────────────────────────────────

model ExternalShip {
  id        String    @id @default(cuid())
  name      String
  imo       String?
  mmsi      String?   @unique
  lat       Float?
  lng       Float?
  status    String?
  eta       DateTime?
  source    String    @default("marinetraffic")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  ships     Ship[]

  @@map("external_ships")
}

// ── Login Logs ───────────────────────────────────────────────────────────────

model LoginLog {
  id         Int      @id @default(autoincrement())
  user_id    String?  @db.Uuid
  full_name  String
  email      String
  event_type String   @default("LOGIN")
  created_at DateTime @default(now()) @db.Timestamptz()
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([created_at(sort: Desc)])
  @@map("login_logs")
}

// ── Tool Requests ────────────────────────────────────────────────────────────

model ToolRequest {
  id             String   @id @default(uuid()) @db.Uuid
  tool_name      String
  quantity       Int      @default(1)
  reason         String
  status         String   @default("PENDENTE")
  requested_by   String
  responded_by   String?
  response_notes String?
  // Foto opcional do produto (data URL base64 comprimida no cliente). Guardada
  // inline no banco porque a infra é só Railway/Postgres, sem storage externo.
  image_url      String?
  // Link do produto (Mercado Livre etc.) + dados puxados automaticamente da
  // página (Open Graph / JSON-LD) ao colar o link na Nova Solicitação.
  product_url     String?
  estimated_value Decimal? @db.Decimal(10, 2)
  supplier        String?
  // Destino sugerido no Almoxarifado (ESTOQUE/RANCHO/EPI/UNIFORME/MAQUINARIO/
  // ESCRITORIO/OUTROS). O gestor confirma/ajusta ao aprovar.
  department      String?
  // Código do item no Almoxarifado (ex.: "AR01") — quando informado, o abastecimento
  // repõe exatamente aquele item do setor de destino, em vez de casar pelo nome. O
  // código é derivado (gerado por setor a partir do nome); ver buildCodeMap em utils.ts.
  code            String?
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @default(now()) @db.Timestamptz()

  @@index([status])
  @@index([created_at(sort: Desc)])
  @@map("tool_requests")
}

// ── Purchase Orders (Controle de Compras) ────────────────────────────────────
// Registro das compras efetivamente realizadas, inspirado na planilha oficial
// "PLANILHA DE COMPRAS - CARGO". Uma compra pode (opcionalmente) ter origem numa
// solicitação aprovada (request_id) ou ser lançada direto (compras avulsas como
// rancho, água, combustível, etc.).

model PurchaseOrder {
  id             String    @id @default(uuid()) @db.Uuid
  description    String // DESCRIÇÃO
  department     String? // DEPARTAMENTO: MANUTENÇÃO, ESCRITÓRIO, OPERAÇÃO, RANCHO, EPI, OUTROS
  code           String? // CÓDIGO do item no Almoxarifado (ex.: "AR01") — repõe exatamente aquele item ao abastecer (derivado; ver buildCodeMap em utils.ts)
  supplier       String? // FORNECEDOR
  purchase_date  DateTime? @db.Date // DATA DA COMPRA
  unit_value     Float     @default(0) // VALOR unit. (R$)
  quantity       Float     @default(1) // QUANTIDADE
  total_value    Float     @default(0) // VALOR total (R$) = unit_value * quantity
  payment_method String? // FORMA DE PAGAMENTO
  // Prazo em dias quando FORMA DE PAGAMENTO = FATURADO. O vencimento no Contas a
  // Pagar sai de purchase_date + payment_term_days (controle de meses futuros).
  // Legado: com payment_terms preenchido, guarda só a 1ª parcela.
  payment_term_days Int?
  // Parcelas do FATURADO: prazo em dias de cada pagamento (ex.: [28, 35, 42]).
  // O valor total é dividido igualmente entre as parcelas e cada uma vira um
  // título próprio no Contas a Pagar (compra parcelada pelo fornecedor).
  payment_terms Int[] @default([])
  // Cartão usado quando FORMA DE PAGAMENTO = CARTÃO DE CRÉDITO (só marca qual foi,
  // pra saber o fechamento; a fatura do cartão é lançada como um boleto à parte).
  card_id        Int?
  card           Card?     @relation(fields: [card_id], references: [id], onDelete: SetNull)
  notes          String? // OBSERVAÇÃO
  image_url      String? // foto do produto (herdada da solicitação ou anexada)
  product_url    String? // link do produto (Mercado Livre etc.), usado pra puxar nome/valor/foto
  request_id     String?   @db.Uuid // solicitação de origem, se houver
  // Navio vinculado (aba Navios), opcional. ship_id é o link; ship_name é um
  // snapshot do nome no momento da compra — navios são apagáveis, então guardar o
  // nome preserva o histórico/relatório mesmo depois que o navio sai da lista.
  ship_id        String?   @db.Uuid
  ship_name      String? // NAVIO (snapshot do nome)
  created_by     String
  created_at     DateTime  @default(now()) @db.Timestamptz()
  updated_at     DateTime  @default(now()) @db.Timestamptz()

  // Títulos de Contas a Pagar gerados a partir desta compra, se houver —
  // FATURADO parcelado gera um título por parcela.
  payable_invoices PayableInvoice[]

  @@index([purchase_date(sort: Desc)])
  @@index([department])
  @@index([request_id])
  @@index([ship_id])
  @@index([card_id])
  @@map("purchase_orders")
}

// Cartão de crédito vinculado a uma conta bancária (aba Contas bancárias da
// Conciliação). Guarda os 4 últimos dígitos e o dia de fechamento da fatura —
// assim dá pra saber, numa compra no cartão, qual cartão foi usado e quando ele
// fecha. A fatura em si vira um boleto no Contas a Pagar (lançamento à parte).
model Card {
  id              Int         @id @default(autoincrement())
  bank_account_id Int
  bank_accounts   BankAccount @relation(fields: [bank_account_id], references: [id], onDelete: Cascade)
  last4           String // 4 últimos dígitos
  closing_day     Int // dia do mês em que a fatura fecha (1-31)
  label           String? // apelido opcional (ex.: "Itaú 8168")
  active          Boolean     @default(true)
  created_by      String
  created_at      DateTime    @default(now()) @db.Timestamptz()

  purchases PurchaseOrder[]

  @@index([bank_account_id])
  @@map("cards")
}

// ── Suppliers (Fornecedores) ─────────────────────────────────────────────────

model Supplier {
  id         Int      @id @default(autoincrement())
  name       String
  contact    String?
  address    String?
  category   String?
  website    String?
  notes      String?
  // CNPJ (só dígitos) — chave de casamento do Contas a Pagar: boleto extraído
  // por e-mail e favorecido do extrato bancário casam com o fornecedor por aqui.
  cnpj       String?  @unique
  email      String?
  created_by String
  updated_at DateTime @default(now()) @db.Timestamptz()
  updated_by String

  payable_invoices PayableInvoice[]
  recurring_bills  RecurringBill[]

  @@map("suppliers")
}

// ── Product Links ────────────────────────────────────────────────────────────

model ProductLink {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  url         String
  category    String   @default("Outros")
  description String?
  created_by  String
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @db.Timestamptz()

  @@index([category])
  @@map("product_links")
}

// ── WhatsApp Messages ───────────────────────────────────────────────────────
// Persisted history of every message we receive via Evolution webhook plus
// every message we send from the app. `remote_jid` groups messages into
// conversations — individual chats end with @s.whatsapp.net, groups with @g.us.

model WhatsappMessage {
  id              String   @id @default(uuid()) @db.Uuid
  message_id      String?                                  // Evolution's key.id (may collide across instances, hence not unique alone)
  instance_name   String
  remote_jid      String                                   // conversation partner (number@s.whatsapp.net or groupId@g.us)
  from_me         Boolean  @default(false)
  push_name       String?                                  // display name from WhatsApp (sender's)
  message_type    String                                   // conversation, imageMessage, audioMessage, videoMessage, documentMessage, ...
  text            String?                                  // text content or caption
  media_mimetype  String?                                  // image/jpeg, audio/ogg, etc
  media_filename  String?                                  // for documentMessage
  timestamp_ms    BigInt                                   // WhatsApp's messageTimestamp (seconds) * 1000
  sent_by_user_id String?                                  // if from_me and originated in our app, the user id
  raw_event       Json?                                    // full Evolution webhook payload for debugging
  created_at      DateTime @default(now()) @db.Timestamptz()

  @@index([remote_jid, timestamp_ms(sort: Desc)])
  @@index([timestamp_ms(sort: Desc)])
  @@unique([instance_name, message_id, remote_jid], name: "unique_message")
  @@map("whatsapp_messages")
}

// Vínculo manual "participante (LID) -> telefone". O WhatsApp às vezes entrega
// mensagens identificando o remetente só por um "LID" opaco (id de privacidade)
// sem expor o número, então não dá pra descobrir quem é automaticamente. Aqui o
// usuário informa o telefone daquele LID; o nome passa a ser resolvido pelo
// telefone (casando com Colaboradores) no thread e no painel do grupo.
model WhatsappLidAlias {
  lid        String   @id // dígitos do LID, ex.: "126581477499056"
  phone      String? // telefone informado (dígitos, normalizado com 55)
  created_by String
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  @@map("whatsapp_lid_aliases")
}

// ── Marketing: cadastro de clientes para prospecção por email ─────────────────
// Lista de clientes/contatos usada na aba Marketing para reaproveitar no envio
// de email (selecionar um cliente preenche destinatário e saudação).
model MarketingClient {
  id         Int      @id @default(autoincrement())
  name       String                                    // nome / razão social
  company    String?                                   // empresa (se diferente do nome)
  email      String?
  phone      String?
  cnpj       String?
  city       String?
  state      String?                                   // UF
  notes      String?
  created_by String
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @updatedAt @db.Timestamptz()

  @@map("marketing_clients")
}

// ── Mensagens agendadas: boletins recorrentes enviados a grupos do WhatsApp ───
// Cada linha é uma mensagem que o scheduler (src/lib/services/scheduler.ts)
// dispara num grupo em horário recorrente (DIÁRIO/SEMANAL, fuso America/Sao_Paulo).
// O conteúdo é montado com dados AO VIVO no momento do envio (estoque de EPI/
// uniforme ou prontidão) — por isso guardamos o "tipo de template", não o texto.
enum ScheduleTemplateKind {
  EPI
  UNIFORME
  PRONTIDAO
  COMPRAS
  CUSTOM
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
}

model ScheduledMessage {
  id          String               @id @default(uuid()) @db.Uuid
  group_jid   String // grupo destino (...@g.us)
  group_label String? // nome do grupo no cadastro (exibição + push_name do stub)
  template    ScheduleTemplateKind
  team        String? // PRONTIDAO: EQUIPE_1/EQUIPE_2/EQUIPE_3/ALL; senão null
  header_text String? // texto fixo prefixado antes do template ao vivo
  body_text   String? // CUSTOM: corpo completo; ignorado nos demais
  frequency   ScheduleFrequency
  weekday     Int? // 0=Dom..6=Sáb (obrigatório em WEEKLY)
  hour        Int // 0-23 horário local (America/Sao_Paulo)
  minute      Int // 0-59 horário local
  enabled     Boolean              @default(true)
  sort_order  Int                  @default(0) // ordem de disparo quando vários caem no mesmo horário (menor = primeiro)
  next_run_at DateTime?            @db.Timestamptz() // próximo disparo em UTC (null quando desabilitado)
  last_run_at DateTime?            @db.Timestamptz()
  last_status String? // "ok" | "error: ..."
  created_by  String?
  created_at  DateTime             @default(now()) @db.Timestamptz()
  updated_at  DateTime             @default(now()) @updatedAt @db.Timestamptz()

  @@index([enabled, next_run_at])
  @@map("scheduled_messages")
}

// ── Contas a Pagar + Conciliação Bancária ────────────────────────────────────
// Módulo de fornecedores/bancos (docs/financeiro/). Não confundir com o
// Financeiro de folha (Job/JobAllocation), que é pagamento a colaboradores.

// Máquina de estados (transições válidas em src/lib/services/payable-status.ts):
// RECEBIDO → AGUARDANDO_APROVACAO → APROVADO → PAGO; CANCELADO a partir de
// qualquer estado não-pago.
enum PayableStatus {
  RECEBIDO
  AGUARDANDO_APROVACAO
  APROVADO
  PAGO
  CANCELADO
}

enum PayableOrigin {
  EMAIL // capturado da caixa integrada (Microsoft Graph)
  MANUAL // lançado à mão na UI
  BOLETO_PDF // importado de um PDF de boleto
  EXTRATO // gerado do débito de um extrato OFX (já pago)
  COMPRA // puxado de um registro do Controle de Compras (purchase_orders)
  DEMONSTRACAO // migrado/sincronizado da planilha da Demonstração Financeira
}

enum BankKind {
  ITAU
  SANTANDER
  OUTRO
}

// De onde veio a movimentação bancária — arquivo importado ou API direta.
enum TransactionSource {
  OFX_FILE
  CNAB_FILE
  API_ITAU
  API_SANTANDER
}

enum ReconciliationStatus {
  SUGERIDA // motor achou candidato com score intermediário; espera revisão
  CONFIRMADA // conciliada (automática por score alto ou aceita na revisão)
  REJEITADA // revisor descartou a sugestão
}

enum FinanceJobStatus {
  PENDENTE
  PROCESSANDO
  CONCLUIDO
  ERRO
}

// Título a pagar. Nasce RECEBIDO quando capturado por e-mail; lançamentos
// manuais podem nascer direto em AGUARDANDO_APROVACAO.
// Conta mensal (recorrente) do Contas a Pagar — o modelo, não o título.
// Aluguel, CPFL, contabilidade etc. voltam todo mês: o materializador
// (src/lib/services/recurring-bills.ts) gera o título do mês atual e do
// próximo automaticamente (idempotente via @@unique em PayableInvoice), já
// APROVADO, vencendo no due_day. `active` desliga a recorrência sem apagar o
// histórico; end_month encerra num mês certo.
model RecurringBill {
  id          Int      @id @default(autoincrement())
  description String
  amount      Decimal  @db.Decimal(12, 2)
  due_day     Int // dia do vencimento (1-31; meses curtos clampam pro último dia)
  supplier_id Int?
  suppliers   Supplier? @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  payee_name  String?
  bank        String?
  expense_type String?
  // Seção da Demonstração Financeira — os títulos gerados já nascem na seção.
  statement_section String?
  notes       String?
  active      Boolean  @default(true)
  start_month String // "YYYY-MM" — primeiro mês gerado (evita duplicar meses que já existem à mão)
  end_month   String? // "YYYY-MM" — último mês (null = até desativar)
  created_by  String
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz()

  invoices PayableInvoice[]

  @@map("recurring_bills")
}

model PayableInvoice {
  id          String         @id @default(uuid()) @db.Uuid
  supplier_id Int?
  suppliers   Supplier?      @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  description String
  amount      Decimal        @db.Decimal(12, 2)
  due_date    DateTime?      @db.Date
  status      PayableStatus  @default(RECEBIDO)
  origin      PayableOrigin  @default(MANUAL)

  // Dados extraídos do boleto (padrão FEBRABAN). A linha digitável identifica o
  // título unicamente — é a dedupe primária: o mesmo boleto reenviado por
  // e-mail não gera segundo lançamento.
  digitable_line String? @unique
  barcode        String?
  payee_name     String? // beneficiário como está no boleto
  payee_document String? // CNPJ/CPF do beneficiário (só dígitos)

  // ── Colunas do controle de vencimentos (PLANILHA DE VENCIMENTO) ──────────
  bank         String? // "BANCO" — de qual conta saiu/vai sair (Itaú/Santander)
  expense_type String? // "TIPO DE DESPESA"
  // Forma de pagamento — mesmos rótulos do Controle de Compras (PIX, DINHEIRO,
  // BOLETO, CARTÃO DE CRÉDITO/DÉBITO, FATURADO, TRANSFERÊNCIA). Título vindo de
  // compra herda a forma dela; usado pelo filtro do Contas a Pagar.
  payment_method String?
  // Classificação p/ filtro: "MENSAL" (despesa que repete todo mês — aluguel,
  // consultoria, infraestrutura...) ou "UNICA". É só a etiqueta de filtragem;
  // a geração automática de fato fica a cargo da RecurringBill (recurring_bill_id).
  recurrence   String  @default("UNICA")
  // Seção da Demonstração Financeira ("6.1".."12" — rótulos em
  // src/lib/demonstracao-financeira.ts). Título com seção aparece na aba
  // Demonstração Financeira, agrupado por seção; o Contas a Pagar mostra tudo.
  statement_section String?
  paid_amount  Decimal? @db.Decimal(12, 2) // "VALOR PAGO" (pode diferir do valor em pagamento parcial/rateado)
  payment_date DateTime? @db.Date          // "DATA DE PAGTO"
  // Idempotência do import de extrato OFX: sha256(banco+data+valor+memo+ocorr.).
  import_hash  String?  @unique

  notes String?

  // Origem "Controle de Compras": quando o título nasce de um registro de
  // purchase_orders, guarda o vínculo pra não puxar a mesma compra duas vezes e
  // pra referência cruzada. Não é mais único: FATURADO parcelado gera um título
  // por parcela da mesma compra. SetNull preserva o título se a compra sumir.
  purchase_order_id String?        @db.Uuid
  purchase_order    PurchaseOrder? @relation(fields: [purchase_order_id], references: [id], onDelete: SetNull)

  // Conta mensal que gerou este título (null = conta única). O par
  // (recorrência, vencimento) é único — é o que torna o materializador
  // idempotente. SetNull preserva o título se a recorrência for apagada.
  recurring_bill_id Int?
  recurring_bill    RecurringBill? @relation(fields: [recurring_bill_id], references: [id], onDelete: SetNull)

  // ── Trilha de auditoria da máquina de estados ────────────────────────────
  approved_by   String?
  approved_at   DateTime? @db.Timestamptz()
  paid_by       String?
  paid_at       DateTime? @db.Timestamptz()
  cancelled_by  String?
  cancelled_at  DateTime? @db.Timestamptz()
  cancel_reason String?

  created_by String
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  attachments     InvoiceAttachment[]
  reconciliations Reconciliation[]

  @@index([status])
  @@index([due_date])
  @@index([supplier_id])
  @@index([purchase_order_id])
  @@index([statement_section])
  @@index([recurring_bill_id])
  @@unique([recurring_bill_id, due_date])
  @@map("payable_invoices")
}

// PDF original do boleto, inline no Postgres (infra só Railway, sem storage
// externo — mesmo racional de StockItem.image_url, mas em Bytes, não base64).
model InvoiceAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  invoice_id String   @db.Uuid
  invoices   PayableInvoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  filename   String
  mime_type  String   @default("application/pdf")
  content    Bytes
  // SHA-256 do conteúdo — dedupe global: o mesmo arquivo nunca entra duas vezes.
  sha256     String   @unique
  // id da mensagem no Graph quando veio por e-mail (rastreabilidade).
  source_message_id String?
  created_by String
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([invoice_id])
  @@map("invoice_attachments")
}

model BankAccount {
  id             Int      @id @default(autoincrement())
  bank           BankKind
  nickname       String // ex.: "Itaú principal"
  agency         String?
  account_number String?
  active         Boolean  @default(true)
  // Saldo antes da primeira movimentação (semente do saldo corrente no extrato
  // e no Excel de conciliação). Preenchido do "SALDO ANTERIOR" do 1º OFX
  // importado; ajustável pelo usuário.
  opening_balance Decimal @default(0) @db.Decimal(14, 2)
  // true quando o provider de API (Fase 6) está habilitado pra esta conta;
  // enquanto false a conta só recebe movimentações por arquivo (OFX/CNAB).
  api_enabled    Boolean  @default(false)
  created_by     String
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz()

  transactions BankTransaction[]
  cards        Card[]

  @@map("bank_accounts")
}

// Movimentação bancária normalizada — TODA fonte (OFX, CNAB, API Itaú/Santander)
// converge pra este formato via BancoProvider; o motor de conciliação só conhece
// este model, nunca o formato nativo do banco.
model BankTransaction {
  id              String            @id @default(uuid()) @db.Uuid
  bank_account_id Int
  bank_accounts   BankAccount       @relation(fields: [bank_account_id], references: [id], onDelete: Cascade)
  posted_at       DateTime          @db.Date
  // Valor com sinal: negativo = débito (pagamento), positivo = crédito.
  amount          Decimal           @db.Decimal(12, 2)
  description     String?
  payee_name      String? // favorecido, quando a fonte informa
  payee_document  String? // CNPJ/CPF do favorecido (só dígitos)
  // Id externo da transação (FITID do OFX / id da API). Único por conta.
  external_id     String?
  // Fallback de idempotência pra fontes sem id externo confiável:
  // sha256(conta + data + valor + descrição + ocorrência). Único por conta.
  // (Ex.: no OFX do Santander o FITID se repete no mesmo arquivo, então não dá
  // pra usar como external_id — o dedupe_hash é quem garante idempotência.)
  dedupe_hash     String
  // false = movimentação que NÃO entra na conciliação: transferência interna /
  // aplicação-resgate automático (CONTAMAX, APLIC AUT) e rendimento do sweep.
  // O contador nunca marca "ok" nessas — o motor as ignora e a UI as mostra
  // esmaecidas. Marcadores puros de saldo (SALDO ANTERIOR/DIA do Itaú) nem
  // chegam aqui: são filtrados na importação.
  reconcilable    Boolean           @default(true)
  source          TransactionSource
  // Registro cru da fonte (linha do OFX/CNAB ou JSON da API) pra auditoria.
  raw             Json?
  imported_by     String?
  imported_at     DateTime          @default(now()) @db.Timestamptz()

  // ── Revisão manual (a "marca ok" da planilha da contabilidade) ───────────
  // Independe do casamento com conta a pagar: a linha pode ser conferida e
  // marcada mesmo sem título (tarifa, salário, etc.). Linha conciliada =
  // review_status CONCILIADO OU tem Reconciliation CONFIRMADA.
  review_status   String            @default("PENDENTE") // PENDENTE | CONCILIADO | IGNORADO
  review_note     String?           // "lançamento" reescrito pra exibição/Excel
  reviewed_by     String?
  reviewed_at     DateTime?         @db.Timestamptz()

  reconciliation Reconciliation?

  @@unique([bank_account_id, external_id])
  @@unique([bank_account_id, dedupe_hash])
  @@index([posted_at])
  @@map("bank_transactions")
}

// Resultado do matching: liga UMA movimentação a UM título. A transação só pode
// ter uma conciliação (1:1 via @unique) — idempotência garantida pelo banco.
model Reconciliation {
  id             Int                  @id @default(autoincrement())
  transaction_id String               @unique @db.Uuid
  transactions   BankTransaction      @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  invoice_id     String               @db.Uuid
  invoices       PayableInvoice       @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  status         ReconciliationStatus @default(SUGERIDA)
  // Score 0-100 e motivo legível do match (ex.: "valor exato + CNPJ + data ±1d")
  // — auditoria de POR QUE o motor casou os dois.
  score          Int
  reason         String
  // "AUTO" quando o motor conciliou sozinho; senão o nome do revisor.
  matched_by     String
  decided_by     String?
  decided_at     DateTime?            @db.Timestamptz()
  created_at     DateTime             @default(now()) @db.Timestamptz()

  @@index([invoice_id])
  @@index([status])
  @@map("reconciliations")
}

// Trilha de auditoria das integrações (Graph, bancos, parsers, motor).
model IntegrationLog {
  id         Int      @id @default(autoincrement())
  provider   String // GRAPH, ITAU, SANTANDER, OFX, CNAB, ENGINE
  operation  String // ex.: "delta_sync", "parse_boleto", "listar_movimentacoes"
  ok         Boolean
  message    String?
  details    Json?
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([created_at(sort: Desc)])
  @@index([provider])
  @@map("integration_logs")
}

// Caixa de e-mail monitorada via Microsoft Graph. Tokens SEMPRE criptografados
// (AES-256-GCM, src/lib/crypto.ts) — nunca em texto puro.
model EmailIntegrationAccount {
  id                Int       @id @default(autoincrement())
  mailbox           String    @unique // endereço da caixa
  tenant_id         String?
  access_token_enc  String? // access token criptografado
  refresh_token_enc String? // refresh token criptografado
  token_expires_at  DateTime? @db.Timestamptz()
  // deltaLink da última sincronização — próximo poll só traz o que mudou.
  delta_token       String?
  enabled           Boolean   @default(true)
  last_sync_at      DateTime? @db.Timestamptz()
  last_status       String? // "ok" | "error: ..."
  created_by        String
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz()

  @@map("email_integration_accounts")
}

// Fila de jobs em Postgres, consumida pelo tick do scheduler (instrumentation)
// com SELECT ... FOR UPDATE SKIP LOCKED. Sem Redis: instância única no Railway
// e volume de milhares/mês — ver docs/financeiro/00-arquitetura.md §5.
model FinanceJob {
  id         Int              @id @default(autoincrement())
  kind       String // EMAIL_MESSAGE, PARSE_BOLETO, BANK_SYNC, RECONCILE...
  payload    Json
  // Chave de idempotência (ex.: message id do Graph, sha256 do anexo) — o mesmo
  // trabalho nunca é enfileirado duas vezes.
  dedupe_key String?          @unique
  status     FinanceJobStatus @default(PENDENTE)
  attempts   Int              @default(0)
  last_error String?
  run_after  DateTime?        @db.Timestamptz()
  created_at DateTime         @default(now()) @db.Timestamptz()
  updated_at DateTime         @default(now()) @updatedAt @db.Timestamptz()

  @@index([status, run_after])
  @@map("finance_jobs")
}

// ── Demonstração Financeira ──────────────────────────────────────────────────

// Uma linha da "Demonstração Financeira <ano> - CARGOSHIPS.xlsx" (fonte oficial
// da diretoria: uma aba por mês, seções 6 a 12 lado a lado em blocos de
// Data/Descrição/Valor). Aqui tudo vira um formato só: (ano, mês, seção, data,
// descrição, valor) — a tela reagrupa por seção pra ficar igual à planilha.
//
// A Folha (seção 9) tem 3 colunas de valor na planilha (Salário/Férias/Prêmios);
// cada uma vira uma linha própria com a seção 9.1/9.2/9.3, que é a numeração da
// própria planilha. Assim o TOTAIS de cada bloco bate com a soma daqui.
//
// Populado por scripts/import-demonstracao-financeira.ts (a planilha continua
// sendo a fonte; a aba é leitura). Reimportar um ano apaga e regrava o ano todo.
model FinancialStatementEntry {
  id          Int       @id @default(autoincrement())
  year        Int
  month       Int // 1-12
  // Chave da seção na planilha: "6.1", "6.2", "6.3", "6.4", "7.1", "8.1",
  // "9.1", "9.2", "9.3", "10", "11", "12". Os rótulos ficam no código
  // (src/lib/demonstracao-financeira.ts), não no banco.
  section     String
  // Nem toda linha da planilha tem data preenchida (ex.: contas recorrentes).
  entry_date  DateTime? @db.Date
  description String
  // Valor pode ser negativo — a planilha usa isso pra estorno/crédito.
  value       Decimal   @db.Decimal(12, 2)
  // Linha de origem na aba do mês — rastreia de onde veio quando algo destoa.
  source_row  Int
  imported_by String
  imported_at DateTime  @default(now()) @db.Timestamptz()

  @@index([year, month])
  @@index([year, section])
  @@map("financial_statement_entries")
}

// Seções/subseções que o usuário cria na Demonstração Financeira, além das
// fixas da planilha (src/lib/demonstracao-financeira.ts). `group_label` é o
// grupo onde a subseção aparece (um grupo oficial ou um novo criado pelo
// usuário — o grupo "existe" por ter subseções). O título do Contas a Pagar
// referencia estas com a chave "c<id>" em statement_section.
model CustomStatementSection {
  id          Int      @id @default(autoincrement())
  label       String // rótulo da subseção (ex.: "Marketing Digital")
  group_label String // grupo onde aparece (ex.: "6) Despesas do Escritório" ou novo)
  sort_order  Int      @default(0)
  active      Boolean  @default(true)
  created_by  String
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @updatedAt @db.Timestamptz()

  @@map("custom_statement_sections")
}

// Renomeia uma seção FIXA da planilha (STATEMENT_SECTIONS) sem tocar no dado: a
// chave (ex.: "6.1", "9.2", "12") continua a mesma nos títulos; só o rótulo
// exibido no filtro e no cabeçalho passa a vir daqui. Sem linha = usa o padrão.
model StatementSectionOverride {
  id          Int      @id @default(autoincrement())
  section_key String   @unique // chave builtin: "6.1", "9.2", "12"...
  label       String // novo rótulo exibido (sem numeração)
  created_by  String
  created_at  DateTime @default(now()) @db.Timestamptz()
  updated_at  DateTime @updatedAt @db.Timestamptz()

  @@map("statement_section_overrides")
}
